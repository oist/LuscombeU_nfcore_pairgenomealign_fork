/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/pairgenomealign -profile test_reads,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile - FASTQ'
    config_profile_description = 'Minimal test dataset to check read-to-genome alignment'

    target = params.pipelines_testdata_base_path + 'modules/data/genomics/sarscov2/genome/genome.fasta'
    query  = params.pipelines_testdata_base_path + 'modules/data/genomics/sarscov2/nanopore/fastq/test_2.fastq.gz'
    skip_assembly_qc = true

}
